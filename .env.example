# ============================================================================
# Web UI Absensi — Environment Variables
# ============================================================================
# Copy this file to .env (or .env.production) and customize the values.
# DO NOT commit .env files to version control.
# ============================================================================

# --- Runtime ---
NODE_ENV=production
PORT=3000

# --- Session ---
# REQUIRED in production. Must be at least 32 random characters.
# Generate one with: openssl rand -base64 48
SESSION_SECRET=replace_with_long_random_secret_at_least_32_chars

# --- Logging ---
# Optional. One of: debug, info, warn, error. Defaults to info in production.
LOG_LEVEL=info

# --- Master Database ---
# Optional. Defaults to file:./databases/master.sqlite
# MASTER_DATABASE_URL=file:./databases/master.sqlite

# --- Platform Owner (initial seed) ---
# Used by prisma/seed-master.ts to bootstrap the first owner account.
# Change OWNER_PASSWORD before deploying — defaults are blocked in production.
OWNER_USERNAME=admin
OWNER_PASSWORD=change_me_to_a_strong_password

# --- First Tenant Seed (optional, only used by seed-master.ts) ---
TENANT_ADMIN_PASSWORD=change_me_too

# --- File Storage Paths (optional) ---
# Override default paths if you want to mount different volumes.
# DATA_PATH=/var/lib/web-absensi/data
# BACKUP_PATH=/var/lib/web-absensi/backups
